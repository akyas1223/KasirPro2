<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.KasirPro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2155D3</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.KasirPro" parent="Base.Theme.KasirPro" />

    <style name="RoundedSquare" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.KasirPro.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>